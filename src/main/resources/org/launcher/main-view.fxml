<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>
<StackPane xmlns:fx="http://javafx.com/fxml" fx:controller="org.launcher.controller.MainController" fx:id="rootStackPane">
    <BorderPane style="-fx-font-size: 24px;" xmlns="http://javafx.com/javafx" styleClass="main-container">
        <top>
            <HBox alignment="CENTER" prefWidth="Infinity">
                <Label text="_header_" styleClass="header" fx:id="labelHeader"/>
            </HBox>
        </top>
        <center>
            <FlowPane alignment="CENTER" prefWidth="Infinity" fx:id="appsContainer" styleClass="apps-container">
                <Label text="No apps specified ¯\_(ツ)_/¯" styleClass="apps-container-placeholder" fx:id="appsContainerPlaceholder"/>
            </FlowPane>
        </center>
    </BorderPane>
    <HBox styleClass="system-message-container" alignment="CENTER" maxHeight="-Infinity"  minHeight="40" fx:id="systemMessageContainer">
        <Label styleClass="system-message-text" wrapText="true" fx:id="systemMessage" > Sample text</Label>
    </HBox>
</StackPane>
